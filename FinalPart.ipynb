    "def build_prompt(question, context, mode=\"baseline\"):\n",
    "    \n",
    "    if mode == \"baseline\":\n",
    "        return f\"\"\"Answer the question using the context.\n",
    "\n",
    "Context:\n",
    "{context}\n",
    "\n",
    "Question: {question}\n",
    "Answer:\"\"\"\n",
    "\n",
    "    elif mode == \"short\":\n",
    "        return f\"\"\"Answer using the context. Keep the answer short (1-5 words).\n",
    "\n",
    "Context:\n",
    "{context}\n",
    "\n",
    "Question: {question}\n",
    "Answer:\"\"\"\n",
    "\n",
    "    elif mode == \"exact\":\n",
    "        return f\"\"\"Answer using ONLY words copied EXACTLY from the context.\n",
    "Return the SHORTEST possible answer span.\n",
    "\n",
    "Context:\n",
    "{context}\n",
    "\n",
    "Question: {question}\n",
    "Answer:\"\"\"\n",
    "\n",
    "    elif mode == \"best_guess\":\n",
    "        return f\"\"\"Answer using the context. If unsure, give your BEST concise guess.\n",
    "\n",
    "Context:\n",
    "{context}\n",
    "\n",
    "Question: {question}\n",
    "Answer:\"\"\""
   ]
  },
