    "def show_examples(base_preds, improved_preds, answers, questions, n=10):\n",
    "    shown = 0\n",
    "    for q, a, bp, ip in zip(questions, answers, base_preds, improved_preds):\n",
    "        if shown >= n:\n",
    "            break\n",
    "        if bp != ip:\n",
    "            print(\"=\" * 80)\n",
    "            print(\"Q:\", q)\n",
    "            print(\"Gold:\", a)\n",
    "            print(\"Baseline:\", bp)\n",
    "            print(\"Improved:\", ip)\n",
    "            shown += 1"
   ]
  },
